{
  "name": "mixdog",
  "version": "0.9.36",
  "private": false,
  "type": "module",
  "description": "Standalone mixdog coding-agent CLI/TUI workspace.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tribgames/mixdog.git"
  },
  "bugs": {
    "url": "https://github.com/tribgames/mixdog/issues"
  },
  "homepage": "https://github.com/tribgames/mixdog#readme",
  "keywords": [
    "agent",
    "cli",
    "tui",
    "coding-agent",
    "mcp"
  ],
  "bin": {
    "mixdog": "src/cli.mjs"
  },
  "files": [
    "README.md",
    "scripts/",
    "!scripts/bench/",
    "!scripts/recall-bench-*.txt",
    "src/",
    "!src/tui/dev",
    "vendor/"
  ],
  "scripts": {
    "prepack": "npm run build:tui",
    "prepublishOnly": "node -e \"if(!process.env.CI){console.error('local npm publish is disabled — run the Release workflow: gh workflow run release -f bump=patch');process.exit(1)}\"",
    "start": "node src/cli.mjs",
    "smoke": "node scripts/smoke.mjs && node --test scripts/ship-mode-test.mjs",
    "smoke:all": "npm run smoke && npm run smoke:boot && npm run smoke:tools && npm run smoke:patch && npm run smoke:output && npm run smoke:tui && npm run smoke:freevars && npm run smoke:logguard",
    "smoke:boot": "node scripts/boot-smoke.mjs",
    "smoke:compact": "node scripts/compact-smoke.mjs",
    "smoke:loop": "node scripts/smoke-loop.mjs",
    "smoke:loop:final": "node scripts/smoke-loop-report.mjs --require-complete --min-elapsed 5h --min-iterations 400 --max-gap 60s --max-smoke-ms 10000 --max-avg-smoke-ms 8500 --max-step-ms boot-smoke.mjs=8000 --max-step-ms tool-smoke.mjs=4000 --max-rss-mb 140 --max-rss-growth-mb 50",
    "smoke:loop:report": "node scripts/smoke-loop-report.mjs",
    "smoke:tools": "node scripts/tool-smoke.mjs",
    "smoke:patch": "node scripts/apply-patch-edit-smoke.mjs",
    "smoke:output": "node scripts/output-style-smoke.mjs",
    "smoke:tui": "node scripts/tui-render-smoke.mjs",
    "smoke:freevars": "node scripts/freevar-smoke.mjs",
    "smoke:logguard": "node scripts/log-writer-guard-smoke.mjs",
    "test:toolcall": "node --test scripts/toolcall-args-test.mjs",
    "test:shipmode": "node --test scripts/ship-mode-test.mjs",
    "test:shellhardening": "node --test scripts/shell-hardening-test.mjs",
    "test:placeholder": "node --test scripts/compacted-placeholder-scrub-test.mjs",
    "test:providers": "node --test scripts/provider-toolcall-test.mjs",
    "test:atomiclock": "node --test scripts/atomic-lock-tryonce-test.mjs",
    "test:rebindtail": "node --test scripts/forwarder-rebind-tail-test.mjs",
    "failures": "node scripts/tool-failures.mjs",
    "trace:llm": "node scripts/llm-trace-summary.mjs",
    "diag:sessions": "node scripts/session-diag.mjs",
    "diag:session": "node scripts/session-diag.mjs",
    "bench:session": "node scripts/session-bench.mjs",
    "bench:task": "node scripts/task-bench.mjs",
    "bench:corpus": "node scripts/routing-corpus.mjs",
    "bench:run": "node scripts/bench-run.mjs",
    "bench:recall": "node scripts/recall-bench.mjs",
    "audit:models": "node scripts/model-catalog-audit.mjs",
    "patch:replay": "node scripts/patch-replay.mjs",
    "build:tui": "node scripts/build-tui.mjs",
    "release:patch": "npm run smoke && npm version patch -m \"mixdog v%s\" && git push --follow-tags origin main",
    "release:minor": "npm run smoke && npm version minor -m \"mixdog v%s\" && git push --follow-tags origin main",
    "release:major": "npm run smoke && npm version major -m \"mixdog v%s\" && git push --follow-tags origin main"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "discord.js": "^14.26.4",
    "ink": "^7.1.0",
    "jsdom": "^26.1.0",
    "kiwi-nlp": "^0.21.0",
    "marked": "^14.1.4",
    "node-cron": "^4.5.0",
    "openai": "^6.44.0",
    "pg": "^8.22.0",
    "puppeteer-core": "^25.2.0",
    "react": "^19.2.7",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "undici": "^8.5.0",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "discord.js": {
      "undici": "6.27.0"
    },
    "@discordjs/rest": {
      "undici": "6.27.0"
    }
  },
  "devDependencies": {
    "acorn": "^8.17.0",
    "esbuild": "^0.28.1",
    "eslint-scope": "^9.1.2"
  }
}
