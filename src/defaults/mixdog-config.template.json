{
  "channels": {
    "promptInjection": {
      "mode": "claude_md",
      "targetPath": "~/.claude/CLAUDE.md"
    }
  },
  "memory": {
    "enabled": true,
    "user": { "title": "" },
    "cycle1": { "interval": "10m" },
    "cycle2": { "interval": "1h" }
  },
  "search": {
    "enabled": true,
    "rawSearch": {
      "maxResults": 10,
      "credentials": {
        "firecrawl": { "apiKey": "" },
        "tavily": { "apiKey": "" },
        "exa": { "apiKey": "" }
      }
    },
    "requestTimeoutMs": 120000,
    "crawl": { "maxPages": 10, "maxDepth": 2, "sameDomainOnly": true }
  }
}
