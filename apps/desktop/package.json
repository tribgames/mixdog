{
  "name": "@mixdog/desktop",
  "version": "0.9.56",
  "private": true,
  "description": "Mixdog desktop host for Windows and macOS",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:renderer": "tsc --noEmit --strict --target ES2022 --module ESNext --moduleResolution Bundler --jsx react-jsx --skipLibCheck --types vite/client src/preload/index.d.ts src/shared/contract.ts src/renderer/desktop-api.d.ts src/renderer/renderer-logic.d.mts src/renderer/App.tsx src/renderer/main.tsx",
    "test:renderer": "node --max-old-space-size=1024 --import tsx --test --test-concurrency=1 src/renderer/renderer.test.mjs src/renderer/renderer.dom.test.mjs src/main/engine-host.test.mjs src/main/desktop-diagnostics.test.mjs",
    "test:parity": "tsx --test src/renderer/tui-parity.test.mjs",
    "test:settings": "node --max-old-space-size=1024 --import tsx --test --test-concurrency=1 src/main/settings-store.test.mjs src/renderer/settings/SettingsView.test.mjs",
    "test:packaging": "tsx --test src/main/packaging.test.mjs src/main/window-state.test.mjs",
    "test:updater": "tsx --test src/main/updater-controller.test.mjs",
    "e2e:direct": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/direct-e2e-windows.ps1",
    "e2e:direct:source": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/direct-e2e-windows.ps1 -SourceMode",
    "acceptance:win": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/acceptance-windows.ps1",
    "verify:renderer": "npm run test:renderer && node src/renderer/verify-renderer.mjs && npm run typecheck:renderer",
    "build": "npm run typecheck && electron-vite build",
    "capture:ui": "npm run build && node src/renderer/capture-ui.mjs",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "brand:win": "node scripts/generate-brand-icons.mjs",
    "build:win": "npm run build && npm run prepare:runtime && npm run brand:win && electron-builder --win --x64",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@git-diff-view/react": "*",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@tanstack/react-virtual": "3.14.6",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "pretendard": "^1.3.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^27.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
