{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/preload/index.d.ts",
    "src/shared/**/*.ts",
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx"
  ]
}
