# Normalize line endings: LF in repo, auto on checkout
* text=auto
.gitattributes text eol=lf

# Always LF for shell scripts
*.sh text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.node binary
